# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/_/settings/api
# Both NEXT_PUBLIC_* values are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠ SERVER-SIDE ONLY. NEVER prefix with NEXT_PUBLIC_. Never commit. Never log.
# This key bypasses Row-Level Security and can read/write everything.
# Used only by scripts (seed-admin) and trusted server route handlers.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin seeder ──────────────────────────────────────────────────────────
# Used by `npm run seed:admin`. Provide once, then remove from .env.local.
# The password is hashed by Supabase (bcrypt) before storage; it is never
# written to a file or table in plaintext.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_USERNAME=
SEED_ADMIN_NAME=

# ─── App ───────────────────────────────────────────────────────────────────
# Base URL of the running app — used for OAuth redirect URLs and email links.
# Local dev: http://localhost:3000. Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" only after you've enabled the Google provider in Supabase
# (Authentication → Providers → Google). Hides the button when disabled to
# avoid the "Unsupported provider" error.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
